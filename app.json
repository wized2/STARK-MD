{
  "name": "Endroid Bot",
  "version": "9.0.0",
  "description": "Endroid Bot, a Simple WhatsApp Bot built with NodeJs to Enhance WhatsApp Communication experience",
  "website": "https://endroid.pages.dev",
  "logo": "https://raw.githubusercontent.com/wized2/Endroid-Bot/refs/heads/main/assets/banner.png",
  "keywords": ["STARK-MD", "Whatsapp bot", "Bot", "STARK-MD BOT"],
  "repository": "https://github.com/wized2/STARK-MD",
  "success_url": "/",
  "stack": "container",
  "env": {
    "SESSION_ID": {
      "description": "Put your Session STARK-MD~ID here",
      "value": "STARK-MD:prs:msDP9",
      "required": true
    },
    "SUDO_NUMBERS": {
      "description": "Add multiple numbers with country code without (+), separated by comma",
      "value": "923156287068",
      "required": false
    },
    "ANTI_DELETE": {
      "description": "Enable anti-delete (true/false)",
      "value": "true",
      "required": true
    },
    "AUTO_STATUS_VIEWS": {
      "description": "Auto mark status as seen",
      "value": "true",
      "required": true
    },
    "AUTO_STATUS_REACTS": {
      "description": "Auto react on status",
      "value": "true",
      "required": false
    },
     "OWNER_NUMBER": {
      "description": "Bot owner number",
      "value": "923156287068",
      "required": true
    },
    "OWNER_NAME": {
      "description": "Owner display name",
      "value": "Mudasir Wazir",
      "required": true
    },
    "AUTO_STATUS_EMOJIS": {
      "description": "Custom emojis for auto status reactions",
      "value": "🦋,🍥,🍧,🍨,🍫,🍭,🎀,🎐,🎗️,👑,🇵🇰,🍓,🍇,🧃",
      "required": false
    },
    "AUTO_STATUS_REPLY": {
      "description": "Reply to viewed statuses",
      "value": "false",
      "required": false
    },
    "MODE": {
      "description": "Bot mode: public, private, inbox, groups",
      "value": "public",
      "required": true
    },
    "PACK_NAME": {
      "description": "Sticker pack name",
      "value": "мα∂є ву endroid bot",
      "required": true
    },
    "PREFIX": {
      "description": "Command prefix",
      "value": "/",
      "required": true
    },
    "ANTI_CALL": {
      "description": "Anti-call feature",
      "value": "false",
      "required": false
    },    
    "ANTI_CALL_MSG": {
      "description": "Message when someone calls bot",
      "value": "*📞 ᴄαℓℓ ɴσт αℓℓσωє∂ 📵*",
      "required": false
    }, 
    "BOT_NAME": {
      "description": "Bot name display",
      "value": "Endroid Bot",
      "required": true
    },
    "BOT_PIC": {
      "description": "put Bot menu picture URL",
      "value": "https://raw.githubusercontent.com/wized2/Endroid-Bot/refs/heads/main/assets/banner.png",
      "required": true
    },
    "PRESENCE": {
      "description": "Presence type (typing/recording/online/null)",
      "value": "online",
      "required": true
    },
    "TIME_ZONE": {
      "description": "Your timezone",
      "value": "Asia/Karachi",
      "required": true
    }
  },

  "buildpacks": [
    {
      "url": "https://github.com/heroku/heroku-buildpack-nodejs.git"
    }
  ],
  "stack": "heroku-24"
}
